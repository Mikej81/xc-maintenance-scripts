#!/bin/bash
url=""
method="GET"
body=""
write_out=""
all_args=("$@")

i=0
while [[ $i -lt ${#all_args[@]} ]]; do
    arg="${all_args[$i]}"
    case "$arg" in
        -X) ((i++)); method="${all_args[$i]}" ;;
        -d) ((i++)); body="${all_args[$i]}" ;;
        -w) ((i++)); write_out="${all_args[$i]}" ;;
        -H) ((i++)) ;;
        -4|-s|-S) ;;
        http*|https*) url="$arg" ;;
    esac
    ((i++))
done

if [[ -n "${MOCK_CURL_LOG:-}" ]]; then
    echo "${method}|${url}|${body}" >> "$MOCK_CURL_LOG"
fi

if [[ -n "${MOCK_CURL_FAIL:-}" ]]; then
    exit 1
fi

response_file=""
http_code="${MOCK_CURL_DEFAULT_HTTP_CODE:-200}"

if [[ -n "${MOCK_CURL_ROUTES:-}" && -f "$MOCK_CURL_ROUTES" ]]; then
    while IFS='|' read -r pattern code fixture; do
        [[ -z "$pattern" || "$pattern" == \#* ]] && continue
        if [[ "$url" == $pattern ]]; then
            http_code="$code"
            response_file="$fixture"
            break
        fi
    done < "$MOCK_CURL_ROUTES"
elif [[ -n "${MOCK_CURL_RESPONSE:-}" ]]; then
    response_file="$MOCK_CURL_RESPONSE"
    http_code="${MOCK_CURL_HTTP_CODE:-200}"
fi

if [[ -z "$response_file" && -n "${MOCK_CURL_DEFAULT_RESPONSE:-}" ]]; then
    response_file="$MOCK_CURL_DEFAULT_RESPONSE"
fi

if [[ -n "$response_file" && -f "$response_file" ]]; then
    cat "$response_file"
elif [[ -z "$response_file" ]]; then
    echo '{"error": "mock_curl: no route matched for '"$url"'"}'
fi

if [[ -n "$write_out" ]]; then
    result="${write_out//%\{http_code\}/$http_code}"
    echo -e "$result"
fi
